# ============================================
# AiRecord 后端环境变量配置
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# 🎤 火山引擎 ASR（语音识别）
# 获取方式: https://console.volcengine.com/speech/service/8
VOLCANO_ACCESS_KEY=
VOLCANO_SECRET_KEY=
VOLCANO_APP_ID=

# 🧠 DeepSeek LLM（AI 分析）
# 获取方式: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 📦 数据库（默认 SQLite，无需修改）
# DATABASE_URL=sqlite+aiosqlite:///./airecord.db

# 🌐 服务器地址
# HOST=0.0.0.0
# PORT=8000
